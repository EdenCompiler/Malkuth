;;;; Fonte vetorial 5x7 embutida
;;;;
;;;; Cada glifo é descrito como uma pequena matriz textual. A abordagem elimina
;;;; arquivos de fonte externos e mantém a renderização previsível em produção.

(in-package #:malkuth.font)

(defparameter *glyph-table* (make-hash-table :test #'eql))

(defun install-glyph (character &rest rows)
  (setf (gethash character *glyph-table*) rows))

(mapc (lambda (entry) (apply #'install-glyph entry))
      '((#\A ".###." "#...#" "#...#" "#####" "#...#" "#...#" "#...#")
        (#\B "####." "#...#" "#...#" "####." "#...#" "#...#" "####.")
