        (#\- "....." "....." "....." "#####" "....." "....." ".....")
        (#\_ "....." "....." "....." "....." "....." "....." "#####")
        (#\/ "....#" "...#." "...#." "..#.." ".#..." ".#..." "#....")
        (#\\ "#...." ".#..." ".#..." "..#.." "...#." "...#." "....#")
        (#\+ "....." "..#.." "..#.." "#####" "..#.." "..#.." ".....")
