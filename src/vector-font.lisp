        (#\Q ".###." "#...#" "#...#" "#...#" "#.#.#" "#..#." ".##.#")
        (#\R "####." "#...#" "#...#" "####." "#.#.." "#..#." "#...#")
        (#\S ".####" "#...." "#...." ".###." "....#" "....#" "####.")
        (#\T "#####" "..#.." "..#.." "..#.." "..#.." "..#.." "..#..")
