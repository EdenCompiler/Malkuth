        (#\' "..##." "..##." "...#." "....." "....." "....." ".....")))

(defun base-glyph-character (character)
  "Normaliza letras acentuadas para o glifo-base disponível na fonte 5x7."
  (case (char-upcase character)
    ((#\Á #\À #\Â #\Ã #\Ä) #\A)
    ((#\É #\È #\Ê #\Ë) #\E)
    ((#\Í #\Ì #\Î #\Ï) #\I)
    ((#\Ó #\Ò #\Ô #\Õ #\Ö) #\O)
    ((#\Ú #\Ù #\Û #\Ü) #\U)
    (#\Ç #\C)
    (otherwise (char-upcase character))))

(defun glyph-rows (character)
  (or (gethash (base-glyph-character character) *glyph-table*)
      (gethash #\? *glyph-table*)))

(defun vector-text-width (text &key (scale 1.0) (spacing 1.0))
  (if (zerop (length text)) 0.0
      (- (* (length text) (+ (* 5.0 scale) spacing)) spacing)))

(defun draw-vector-text (drawer x y text &key (scale 1.0) (spacing 1.0))
  "Chama DRAWER para cada célula acesa da fonte 5x7: (x y largura altura)."
  (loop with cursor = (float x 1.0)
        for character across text
        for rows = (glyph-rows character)
        do (loop for row in rows
                 for row-index from 0
                 do (loop for cell across row
                          for column-index from 0
                          when (char= cell #\#)
                            do (funcall drawer
                                        (+ cursor (* column-index scale))
                                        (+ y (* row-index scale))
                                        scale scale)))
           (incf cursor (+ (* 5.0 scale) spacing)))
  nil)
